{
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "{{name}}",
  "description": "{{description}}",
  "url": "{{url}}",
  "logo": "{{logo_url}}",
  "image": "{{image_url}}",
  "telephone": "{{phone}}",
  "email": "{{email}}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{street}}",
    "addressLocality": "{{city}}",
    "addressRegion": "{{region}}",
    "postalCode": "{{postal_code}}",
    "addressCountry": "{{country}}"
  },
  "founder": {
    "@type": "Person",
    "name": "{{founder_name}}"
  },
  "sameAs": ["{{facebook}}", "{{instagram}}", "{{linkedin}}"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{catalog_name}}"
  },
  "paymentAccepted": "{{payment_methods}}",
  "currenciesAccepted": "{{currencies}}"
}
